<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.fxmisc.richtext.CodeArea?>

<fx:root type="BorderPane" xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml/1">
    <center>
        <VBox spacing="10">
            <padding>
                <Insets bottom="15" left="15" right="15" top="15" />
            </padding>
            
            <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="CellProfiler Metadata Pattern Tester" />
            
            <Separator />
            
            <Label text="%pattern.label" />
            <CodeArea fx:id="patternArea" prefHeight="60" wrapText="true" />
            
            <Label text="%converted.label" />
            <TextField fx:id="convertedField" editable="false" style="-fx-background-color: #f0f0f0;" />
            
            <Label text="%groups.label" />
            <TextField fx:id="groupsField" editable="false" style="-fx-background-color: #f0f0f0;" />
            
            <Separator />
            
            <Label text="Preview of Extracted Metadata (from Project Images):" />
            <TableView fx:id="resultsTable" VBox.vgrow="ALWAYS">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
            
            <Separator />
            
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button fx:id="cancelButton" cancelButton="true" style="-fx-min-width: 80px;" text="%button.cancel" />
                <Button fx:id="applyButton" defaultButton="true" style="-fx-min-width: 80px;" text="%button.apply" />
            </HBox>
        </VBox>
    </center>
</fx:root>